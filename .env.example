APP_NAME=RAG Intelligent Customer Service

# LLM provider: openai, ollama, xinference
DEFAULT_LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b

# Xinference is used through its OpenAI-compatible endpoint.
XINFERENCE_BASE_URL=http://localhost:9997/v1
XINFERENCE_API_KEY=xinference
XINFERENCE_CHAT_MODEL=

CHUNK_SIZE=900
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=5

